{
    "name": "aeris-smooth-camera",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "lint": "eslint . --ext .ts,.js",
        "type-check": "tsc --noEmit",
        "ci": "vite build && node scripts/inject-id.js",
        "update-readme": "node scripts/update-readme.js",
        "link:dev": "node scripts/link-dev.js",
        "dev": "pnpm link:dev && vite dev",
        "link:dist": "node scripts/link-dist.js",
        "build": "pnpm link:dist && npm run type-check && vite build && node scripts/inject-id.js",
        "build:rc": "npm run type-check && vite build && node scripts/inject-id.js",
        "postbuild:rc": "dotenv -e .env -- sh -c 'rsync -avz --delete dist/ \"$DEPLOY_HOST_ALIAS:$DEPLOY_PATH\"'"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.6.1",
    "devDependencies": {
        "dotenv-cli": "^8.0.0",
        "eslint": "^9.25.0",
        "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.30.1",
        "vite": "^6.3.2",
        "vite-plugin-static-copy": "^2.3.1"
    },
    "pnpm": {
        "ignoredBuiltDependencies": [
            "esbuild"
        ],
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    },
    "dependencies": {
        "symlink-dir": "^6.0.5"
    }
}
